		"@storybook/sveltekit": "8",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.9.1",
		"bulma": "^1.0.4",
		"bun-types": "^1.3.14",
		"eslint": "^9.25.0",
		"eslint-plugin-svelte": "^3.5.0",
		"globals": "^16.0.0",
		"prettier": "^3.5.0",
